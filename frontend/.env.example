# Frontend API target. Defaults in code to https://empty-mile-ai-api.onrender.com when not set.
VITE_API_BASE_URL=https://empty-mile-ai-api.onrender.com

# Optional: enables real Google Maps in the Fleet Map card.
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_javascript_key

# Optional demo destinations for the Send Broker Email and Driver SMS buttons.
VITE_DEMO_BROKER_EMAIL=broker@example.com
VITE_DEMO_DRIVER_PHONE=+15550100
