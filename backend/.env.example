APP_NAME=Empty Mile AI
DATABASE_URL=sqlite:///./empty_mile_ai.db
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://YOUR-FRONTEND.onrender.com

# AI
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.5-flash

# Google Maps. Recommended: use one restricted key for all enabled Maps APIs.
GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# Optional if you created separate keys by API. App will prefer GOOGLE_MAPS_API_KEY.
ROUTES_API_KEY=
GEOCODING_API_KEY=
PLACES_API_KEY=
MAPS_JAVASCRIPT_API_KEY=
ROUTE_OPTIMIZATION_API_KEY=
DIRECTIONS_API_KEY=
DISTANCE_MATRIX_API_KEY=

DEFAULT_FUEL_PRICE=3.65
DEFAULT_DRIVER_COST_PER_MILE=0.65
DEFAULT_TOLL_PER_MILE=0.03
